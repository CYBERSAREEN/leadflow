# Baileys-based WhatsApp bridge — NO Puppeteer/Chromium
# Memory usage: ~80MB (vs 400-500MB with whatsapp-web.js + Chromium)
FROM node:20-alpine

# Only need basic deps — no Chromium at all
RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY package.json ./
RUN npm install --only=production --legacy-peer-deps

COPY whatsapp ./whatsapp

# Auth session + data directory
RUN mkdir -p /app/data/baileys_auth

EXPOSE 3001

CMD ["node", "whatsapp/server.js"]
