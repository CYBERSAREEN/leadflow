{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://leadflow-backend-pz63.onrender.com/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/ws",
      "dest": "https://leadflow-backend-pz63.onrender.com/ws"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
